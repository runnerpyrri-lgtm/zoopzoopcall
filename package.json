{
  "name": "homebom",
  "private": true,
  "version": "0.14.4",
  "scripts": {
    "test": "pnpm -r test && pnpm validate:web-shell",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm validate:web-shell && pnpm -r build",
    "validate:web-shell": "node scripts/validate-web-shell.mjs",
    "validate:family": "node scripts/verify-family.mjs apps/web/src/generated/robom-family family.lock.json",
    "validate:sw": "node --check apps/web/public/sw.js && node scripts/validate-service-worker-cache-scope.mjs && node --test scripts/service-worker.test.mjs",
    "test:e2e": "pnpm --filter @zoopzoopcall/web test:e2e",
    "audit:prod": "node scripts/audit-production.mjs"
  },
  "devDependencies": {
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7"
  },
  "packageManager": "pnpm@9.15.9"
}
