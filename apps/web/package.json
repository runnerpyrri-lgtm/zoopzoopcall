{
  "name": "@zoopzoopcall/web",
  "version": "0.14.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icons.mjs && tsc --noEmit && vite build && node scripts/sync-family-assets.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:family-assets": "node scripts/sync-family-assets.mjs --check"
  },
  "dependencies": {
    "@zoopzoopcall/core": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
